:{"line":290,"col":5}},"generated_from_span":null},"id":1117,"kind":{"StorageDead":24},"comments_before":[]},{"span":{"data":{"file_id":0,"beg":{"line":290,"col":4},"end":{"line":290,"col":5}},"generated_from_span":null},"id":1118,"kind":{"StorageDead":23},"comments_before":[]},{"span":{"data":{"file_id":0,"beg":{"line":290,"col":4},"end":{"line":290,"col":5}},"generated_from_span":null},"id":1119,"kind":{"StorageDead":9},"comments_before":[]},{"span":{"data":{"file_id":0,"beg":{"line":290,"col":4},"end":{"line":290,"col":5}},"generated_from_span":null},"id":1120,"kind":{"StorageDead":8},"comments_before":[]},{"span":{"data":{"file_id":0,"beg":{"line":290,"col":4},"end":{"line":290,"col":5}},"generated_from_span":null},"id":1121,"kind":{"StorageDead":4},"comments_before":[]},{"span":{"data":{"file_id":0,"beg":{"line":290,"col":4},"end":{"line":290,"col":5}},"generated_from_span":null},"id":1122,"kind":{"StorageDead":3},"comments_before":[]},{"span":{"data":{"file_id":0,"beg":{"line":290,"col":4},"end":{"line":290,"col":5}},"generated_from_span":null},"id":1123,"kind":{"StorageDead":2},"comments_before":[]},{"span":{"data":{"file_id":0,"beg":{"line":290,"col":4},"end":{"line":290,"col":5}},"generated_from_span":null},"id":1124,"kind":{"StorageDead":181},"comments_before":[]},{"span":{"data":{"file_id":0,"beg":{"line":290,"col":4},"end":{"line":290,"col":5}},"generated_from_span":null},"id":1125,"kind":{"StorageDead":180},"comments_before":[]},{"span":{"data":{"file_id":0,"beg":{"line":290,"col":5},"end":{"line":290,"col":5}},"generated_from_span":null},"id":1126,"kind":"Return","comments_before":[]}]},"comments":[[272,["note: l[3] is zero, so its multiples can be skipped"]],[275,["the first half computes the Montgomery adjustment factor n, and begins adding n*l to make limbs divisible by R"]],[282,["limbs is divisible by R now, so we can divide by R by simply storing the upper half as the result"]],[289,["result may be >= l, so attempt to subtract l"]]]}}},{"def_id":7,"item_meta":{"name":[{"Ident":["curve25519_dalek",0]},{"Ident":["scalar",0]},{"Impl":{"Ty":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"Deduplicated":322},"kind":"InherentImplBlock"}}},{"Ident":["montgomery_invert",0]}],"span":{"data":{"file_id":5,"beg":{"line":1171,"col":4},"end":{"line":1224,"col":5}},"generated_from_span":null},"source_text":"pub fn montgomery_invert(&self) -> UnpackedScalar {\n        // Uses the addition chain from\n        // https://briansmith.org/ecc-inversion-addition-chains-01#curve25519_scalar_inversion\n        let    _1 = *self;\n        let   _10 = _1.montgomery_square();\n        let  _100 = _10.montgomery_square();\n        let   _11 = UnpackedScalar::montgomery_mul(&_10,     &_1);\n        let  _101 = UnpackedScalar::montgomery_mul(&_10,    &_11);\n        let  _111 = UnpackedScalar::montgomery_mul(&_10,   &_101);\n        let _1001 = UnpackedScalar::montgomery_mul(&_10,   &_111);\n        let _1011 = UnpackedScalar::montgomery_mul(&_10,  &_1001);\n        let _1111 = UnpackedScalar::montgomery_mul(&_100, &_1011);\n\n        // _10000\n        let mut y = UnpackedScalar::montgomery_mul(&_1111, &_1);\n\n        #[inline]\n        fn square_multiply(y: &mut UnpackedScalar, squarings: usize, x: &UnpackedScalar) {\n            for _ in 0..squarings {\n                *y = y.montgomery_square();\n            }\n            *y = UnpackedScalar::montgomery_mul(y, x);\n        }\n\n        square_multiply(&mut y, 123 + 3, &_101);\n        square_multiply(&mut y,   2 + 2, &_11);\n        square_multiply(&mut y,   1 + 4, &_1111);\n        square_multiply(&mut y,   1 + 4, &_1111);\n        square_multiply(&mut y,       4, &_1001);\n        square_multiply(&mut y,       2, &_11);\n        square_multiply(&mut y,   1 + 4, &_1111);\n        square_multiply(&mut y,   1 + 3, &_101);\n        square_multiply(&mut y,   3 + 3, &_101);\n        square_multiply(&mut y,       3, &_111);\n        square_multiply(&mut y,   1 + 4, &_1111);\n        square_multiply(&mut y,   2 + 3, &_111);\n        square_multiply(&mut y,   2 + 2, &_11);\n        square_multiply(&mut y,   1 + 4, &_1011);\n        square_multiply(&mut y,   2 + 4, &_1011);\n        square_multiply(&mut y,   6 + 4, &_1001);\n        square_multiply(&mut y,   2 + 2, &_11);\n        square_multiply(&mut y,   3 + 2, &_11);\n        square_multiply(&mut y,   3 + 2, &_11);\n        square_multiply(&mut y,   1 + 4, &_1001);\n        square_multiply(&mut y,   1 + 3, &_111);\n        square_multiply(&mut y,   2 + 4, &_1111);\n        square_multiply(&mut y,   1 + 4, &_1011);\n        square_multiply(&mut y,       3, &_101);\n        square_multiply(&mut y,   2 + 4, &_1111);\n        square_multiply(&mut y,       3, &_101);\n        square_multiply(&mut y,   1 + 2, &_11);\n\n        y\n    }","attr_info":{"attributes":[{"DocComment":" Inverts an UnpackedScalar in Montgomery form."},{"Unknown":{"path":"rustfmt::skip","args":null}},{"Unknown":{"path":"allow","args":"clippy::just_underscores_and_digits"}}],"inline":null,"rename":null,"public":true},"is_local":true,"opacity":"Transparent","lang_item":null},"generics":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":5215}],"output":{"Deduplicated":322}},"src":"TopLevel","is_global_initializer":null,"body":{"Structured":{"span":{"data":{"file_id":5,"beg":{"line":1171,"col":4},"end":{"line":1224,"col":5}},"generated_from_span":null},"bound_body_regions":281,"locals":{"arg_count":1,"locals":[{"index":0,"name":null,"span":{"data":{"file_id":5,"beg":{"line":1171,"col":39},"end":{"line":1171,"col":53}},"generated_from_span":null},"ty":{"Deduplicated":322}},{"index":1,"name":"self","span":{"data":{"file_id":5,"beg":