s a real parameter measuring the \"bit excess\" of the limbs.","Precomputation: 64-bit multiply by 19.","","This fits into a u64 whenever 51 + b + lg(19) < 64.","","Since 51 + b + lg(19) < 51 + 4.25 + b","                      = 55.25 + b,","this fits if b < 8.75."]},{"span":{"data":{"file_id":5,"beg":{"line":505,"col":41},"end":{"line":505,"col":42}},"generated_from_span":null},"id":5227,"kind":{"StorageDead":118},"comments_before":[]},{"span":{"data":{"file_id":5,"beg":{"line":505,"col":41},"end":{"line":505,"col":42}},"generated_from_span":null},"id":5228,"kind":{"StorageDead":116},"comments_before":[]},{"span":{"data":{"file_id":16,"beg":{"line":290,"col":36},"end":{"line":290,"col":37}},"generated_from_span":null},"id":5229,"kind":{"StorageDead":117},"comments_before":[]},{"span":{"data":{"file_id":16,"beg":{"line":290,"col":12},"end":{"line":290,"col":37}},"generated_from_span":null},"id":5231,"kind":{"Abort":{"Panic":[{"Ident":["core",0]},{"Ident":["panicking",0]},{"Ident":["panic",0]}]}},"comments_before":[]}]},"comments":[[459,["/ Multiply two 64-bit integers with 128 bits of output."]],[472,["Precondition: assume input limbs a[i] are bounded as","","a[i] < 2^(51 + b)","","where b is a real parameter measuring the \"bit excess\" of the limbs."]],[480,["Precomputation: 64-bit multiply by 19.","","This fits into a u64 whenever 51 + b + lg(19) < 64.","","Since 51 + b + lg(19) < 51 + 4.25 + b","                      = 55.25 + b,","this fits if b < 8.75."]],[488,["Multiply to get 128-bit coefficients of output.","","The 128-bit multiplications by 2 turn into 1 slr + 1 slrd each,","which doesn't seem any better or worse than doing them as precomputations","on the 64-bit inputs."]],[505,["Same bound as in multiply:","   c[i] < 2^(102 + 2*b) * (1+i + (4-i)*19)","        < 2^(102 + lg(1 + 4*19) + 2*b)","        < 2^(108.27 + 2*b)","","The carry (c[i] >> 51) fits into a u64 when","   108.27 + 2*b - 51 < 64","   2*b < 6.73","   b < 3.365.","","So we require b < 3 to ensure this fits."]],[515,["Casting to u64 and back tells the compiler that the carry is bounded by 2^64, so","that the addition is a u128 + u64 rather than u128 + u128."]],[544,["To see that this does not overflow, we need a[0] + carry * 19 < 2^64.","","c4 < a2^2 + 2*a0*a4 + 2*a1*a3 + (carry from c3)","   < 2^(102 + 2*b + lg(5)) + 2^64.","","When b < 3 we get","","c4 < 2^110.33  so that carry < 2^59.33","","so that","","a[0] + carry * 19 < 2^51 + 19 * 2^59.33 < 2^63.58","","and there is no overflow."]],[547,["Now a[1] < 2^51 + 2^(64 -51) = 2^51 + 2^13 < 2^(51 + epsilon)."]],[551,["Now all a[i] < 2^(51 + epsilon) and a = self^(2^k)."]]]}}},{"def_id":35,"item_meta":{"name":[{"Ident":["curve25519_dalek",0]},{"Ident":["backend",0]},{"Ident":["serial",0]},{"Ident":["u64",0]},{"Ident":["field",0]},{"Impl":{"Ty":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"Deduplicated":532},"kind":"InherentImplBlock"}}},{"Ident":["square",0]}],"span":{"data":{"file_id":5,"beg":{"line":562,"col":4},"end":{"line":564,"col":5}},"generated_from_span":null},"source_text":"pub fn square(&self) -> FieldElement51 {\n        self.pow2k(1)\n    }","attr_info":{"attributes":[{"DocComment":" Returns the square of this field element."}],"inline":null,"rename":null,"public":true},"is_local":true,"opacity":"Transparent","lang_item":null},"generics":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":6987}],"output":{"Deduplicated":532}},"src":"TopLevel","is_global_initializer":null,"body":{"Structured":{"span":{"data":{"file_id":5,"beg":{"line":562,"col":4},"end":{"line":564,"col":5}},"generated_from_span":null},"bound_body_regions":5,"locals":{"arg_count":1,"locals":[{"index":0,"name":null,"span":