nt":""},{"DocComment":" Note that `Rhs` is `Self` by default, but this is not mandatory. For"},{"DocComment":" example, [`std::time::SystemTime`] implements `Sub<Duration>`, which permits"},{"DocComment":" operations of the form `SystemTime = SystemTime - Duration`."},{"DocComment":""},{"DocComment":" [`std::time::SystemTime`]: ../../std/time/struct.SystemTime.html"},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ## `Sub`tractable points"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ops::Sub;"},{"DocComment":""},{"DocComment":" #[derive(Debug, Copy, Clone, PartialEq)]"},{"DocComment":" struct Point {"},{"DocComment":"     x: i32,"},{"DocComment":"     y: i32,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" impl Sub for Point {"},{"DocComment":"     type Output = Self;"},{"DocComment":""},{"DocComment":"     fn sub(self, other: Self) -> Self::Output {"},{"DocComment":"         Self {"},{"DocComment":"             x: self.x - other.x,"},{"DocComment":"             y: self.y - other.y,"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" assert_eq!(Point { x: 3, y: 3 } - Point { x: 2, y: 3 },"},{"DocComment":"            Point { x: 1, y: 0 });"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" ## Implementing `Sub` with generics"},{"DocComment":""},{"DocComment":" Here is an example of the same `Point` struct implementing the `Sub` trait"},{"DocComment":" using generics."},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ops::Sub;"},{"DocComment":""},{"DocComment":" #[derive(Debug, PartialEq)]"},{"DocComment":" struct Point<T> {"},{"DocComment":"     x: T,"},{"DocComment":"     y: T,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" // Notice that the implementation uses the associated type `Output`."},{"DocComment":" impl<T: Sub<Output = T>> Sub for Point<T> {"},{"DocComment":"     type Output = Self;"},{"DocComment":""},{"DocComment":"     fn sub(self, other: Self) -> Self::Output {"},{"DocComment":"         Point {"},{"DocComment":"             x: self.x - other.x,"},{"DocComment":"             y: self.y - other.y,"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" assert_eq!(Point { x: 2, y: 3 } - Point { x: 1, y: 0 },"},{"DocComment":"            Point { x: 1, y: 3 });"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"sub"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"},{"index":1,"name":"Rhs"},{"index":2,"name":"Self_Output"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[null],"methods":[{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"sub","attr_info":{"attributes":[{"DocComment":" Performs the `-` operation."},{"DocComment":""},{"DocComment":" # Example"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" assert_eq!(12 - 1, 11);"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":6983},{"Deduplicated":6984}],"output":{"Deduplicated":6994}},"item":{"id":51,"generics":{"regions":[],"types":[{"Deduplicated":6983},{"Deduplicated":6984},{"Deduplicated":6994}],"const_generics":[],"trait_refs":[{"HashConsedValue":[7025,{"kind":"SelfId","trait_decl_ref":{"regions":[],"skip_binder":{"id":11,"generics":{"regions":[],"types":[{"Deduplicated":6983},{"Deduplicated":6984},{"Deduplicated":6994}],"const_generics":[],"trait_refs":[]}}}}]}]}}},"kind":{"TraitMethod":[11,0]}}],"vtable":{"id":{"Adt":16},"generics":{"regions":[],"types":[{"Deduplicated":6984},{"Deduplicated":6994}],"const_generics":[],"trait_refs":[]}}},{"def_id":12,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["ops",0]},{"Ident":["arith",0]},{"Ident":["MulAssign",0]}],"span":{"data":{"file_id":12,"beg":{"line":901,"col":0},"end":{"line":901,"col":37}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" The multiplication assignment operator `*=`."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ops::MulAssign;"},{"DocComment":""},{"DocComment":" #[derive(Debug, PartialEq)]"},{"DocComment":" struct Frequency { hertz: f64 }"},{"DocComment":""},{"DocComment":" impl MulAssign<f64> for Frequency {"},{"DocComment":"     fn mul_assign(&mut self, rhs: f64) {"},{"DocComment":"         self.hertz *= rhs;"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" let mut frequency = Frequency { hertz: 50.0 };"},{"DocComment":" frequency *= 4.0;"},{"DocComment":" assert_eq!(Frequency { hertz: 200.0 }, frequency);"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"mul_assign"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"},{"index":1,"name":"Rhs"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[],"methods":[{"params":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"mul_assign","attr_info":{"attributes":[{"DocComment":" Performs the `*=` operation."},{"DocComment":""},{"DocComment":" # Example"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let mut x: u32 = 12;"},{"DocComment":" x *= 2;"},{"DocComment":" assert_eq!(x, 24);"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":7020},{"Deduplicated":6984}],"output":{"Deduplicated":584}},"item":{"id":52,"generics":{"regions":[{"Var":{"Bound":[0,0]}}],"types":[{"Deduplicated":6983},{"Deduplicated":6984}],"const_generics":[],"trait_refs":[{"HashConsedValue":[7026,{"kind":"SelfId","trait_decl_ref":{"regions":[],"skip_binder":{"id":12,"generics":{"regions":[],"types":[{"Deduplicated":6983},{"Deduplicated":6984}],"const_generics":[],"trait_refs":[]}}}}]}]}}},"kind":{"TraitMethod":[12,0]}}],"vtable":{"id":{"Adt":17},"generics":{"regions":[],"types":[{"Deduplicated":6984}],"const_generics":[],"trait_refs":[]}}},{"def_id":13,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["ops",0]},{"Ident":["arith",0]},{"Ident":["Mul",0]}],"span":{"data":{"file_id":12,"beg":{"line":322,"col":0},"end":{"line":322,"col":31}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" The multiplication operator `*`."},{"DocComment":""},{"DocComment":" Note that `Rhs` is `Self` by default, but this is not mandatory."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ## `Mul`tipliable rational numbers"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ops::Mul;"},{"DocComment":""},{"DocComment":" // By the fundamental theorem of arithmetic, rational numbers in lowest"},{"DocComment":" // terms are unique. So, by keeping `Rational`s in reduced form, we can"},{"DocComment":" // derive `Eq` and `PartialEq`."},{"DocComment":" #[derive(Debug, Eq, PartialEq)]"},{"DocComment":" struct Rational {"},{"DocComment":"     numerator: usize,"},{"DocComment":"     denominator: usize,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" impl Rational {"},{"DocComment":"     fn new(numerator: usize, denominator: usize) -> Self {"},{"DocComment":"         if denominator == 0 {"},{"DocComment":"             panic!(\"Zero is an invalid denominator!\");"},{"DocComment":"         }"},{"DocComment":""},{"DocComment":"         // Reduce to lowest terms by dividing by the greatest common"},{"DocComment":"         // divisor."},{"DocComment":"         let gcd = gcd(numerator, denominator);"},{"DocComment":"         Self {"},{"DocComment":"             numerator: numerator / gcd,"},{"DocComment":"             denominator: denominator / gcd,"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" impl Mul for Rational {"},{"DocComment":"     // The multiplication of rational numbers is a closed operation."},{"DocComment":"     type Output = Self;"},{"DocComment":""},{"DocComment":"     fn mul(self, rhs: Self) -> Self {"},{"DocComment":"         let numerator = self.numerator * rhs.numerator;"},{"DocComment":"         let denominator = self.denominator * rhs.denominator;"},{"DocComment":"         Self::new(numerator, denominator)"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" // Euclid's two-thousand-year-old algorithm for finding the greatest common"},{"DocComment":" // divisor."},{"DocComment":" fn gcd(x: usize, y: usize) -> usize {"},{"DocComment":"     let mut x = x;"},{"DocComment":"     let mut y = y;"},{"DocComment":"     while y != 0 {"},{"DocComment":"         let t = y;"},{"DocComment":"         y = x % y;"},{"DocComment":"         x = t;"},{"DocComment":"     }"},{"DocComment":"     x"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" assert_eq!(Rational::new(1, 2), Rational::new(2, 4));"},{"DocComment":" assert_eq!(Rational::new(2, 3) * Rational::new(3, 4),"},{"DocComment":"            Rational::new(1, 2));"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" ## Multiplying vectors by scalars as in linear algebra"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ops::Mul;"},{"DocComment":""},{"DocComment":" struct Scalar { value: usize }"},{"DocComment":""},{"DocComment":" #[derive(Debug, PartialEq)]"},{"DocComment":" struct Vector { value: Vec<usize> }"},{"DocComment":""},{"DocComment":" impl Mul<Scalar> for Vector {"},{"DocComment":"     type Output = Self;"},{"DocComment":""},{"DocComment":"     fn mul(self, rhs: Scalar) -> Self::Output {"},{"DocComment":"         Self { value: self.value.iter().map(|v| v * rhs.value).collect() }"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" let vector = Vector { value: vec![2, 4, 6] };"},{"DocComment":" let scalar = Scalar { value: 3 };"},{"DocComment":" assert_eq!(vector * scalar, Vector { value: vec![6, 12, 18] });"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"mul"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"},{"index":1,"name":"Rhs"},{"index":2,"name":"Self_Output"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[null],"methods":[{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"mul","attr_info":{"attributes":[{"DocComment":" Performs the `*` operation."},{"DocComment":""},{"DocComment":" # Example"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" assert_eq!(12 * 2, 24);"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":6983},{"Deduplicated":6984}],"output":{"Deduplicated":6994}},"item":{"id":53,"generics":{"regions":[],"types":[{"Deduplicated":6983},{"Deduplicated":6984},{"Deduplicated":6994}],"const_generics":[],"trait_refs":[{"HashConsedValue":[7027,{"kind":"SelfId","trait_decl_ref":{"regions":[],"skip_binder":{"id":13,"generics":{"regions":[],"types":[{"Deduplicated":6983},{"Deduplicated":6984},{"Deduplicated":6994}],"const_generics":[],"trait_refs":[]}}}}]}]}}},"kind":{"TraitMethod":[13,0]}}],"vtable":{"id":{"Adt":18},"generics":{"regions":[],"types":[{"Deduplicated":6984},{"Deduplicated":6994}],"const_generics":[],"trait_refs":[]}}},{"def_id":14,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["ops",0]},{"Ident":["arith",0]},{"Ident":["Neg",0]}],"span":{"data":{"file_id":12,"beg":{"line":690,"col":0},"end":{"line":690,"col":19}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" The unary negation operator `-`."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" An implementation of `Neg` for `Sign`, which allows the use of `-` to"},{"DocComment":" negate its value."},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ops::Neg;"},{"DocComment":""},{"DocComment":" #[derive(Debug, PartialEq)]"},{"DocComment":" enum Sign {"},{"DocComment":"     Negative,"},{"DocComment":"     Zero,"},{"DocComment":"     Positive,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" impl Neg for Sign {"},{"DocComment":"     type Output = Self;"},{"DocComment":""},{"DocComment":"     fn neg(self) -> Self::Output {"},{"DocComment":"         match self {"},{"DocComment":"             Sign::Negative => Sign::Positive,"},{"DocComment":"             Sign::Zero => Sign::Zero,"},{"DocComment":"             Sign::Positive => Sign::Negative,"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" // A negative positive is a negative."},{"DocComment":" assert_eq!(-Sign::Positive, Sign::Negative);"},{"DocComment":" // A double negative is a positive."},{"DocComment":" assert_eq!(-Sign::Negative, Sign::Positive);"},{"DocComment":" // Zero is its own negation."},{"DocComment":" assert_eq!(-Sign::Zero, Sign::Zero);"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"neg"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"},{"index":1,"name":"Self_Output"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[null],"m