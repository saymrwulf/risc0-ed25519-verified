y: 3 });"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" ## Implementing `Add` with generics"},{"DocComment":""},{"DocComment":" Here is an example of the same `Point` struct implementing the `Add` trait"},{"DocComment":" using generics."},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ops::Add;"},{"DocComment":""},{"DocComment":" #[derive(Debug, Copy, Clone, PartialEq)]"},{"DocComment":" struct Point<T> {"},{"DocComment":"     x: T,"},{"DocComment":"     y: T,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" // Notice that the implementation uses the associated type `Output`."},{"DocComment":" impl<T: Add<Output = T>> Add for Point<T> {"},{"DocComment":"     type Output = Self;"},{"DocComment":""},{"DocComment":"     fn add(self, other: Self) -> Self::Output {"},{"DocComment":"         Self {"},{"DocComment":"             x: self.x + other.x,"},{"DocComment":"             y: self.y + other.y,"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" assert_eq!(Point { x: 1, y: 0 } + Point { x: 2, y: 3 },"},{"DocComment":"            Point { x: 3, y: 3 });"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"add"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"},{"index":1,"name":"Rhs"},{"index":2,"name":"Self_Output"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[null],"methods":[{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"add","attr_info":{"attributes":[{"DocComment":" Performs the `+` operation."},{"DocComment":""},{"DocComment":" # Example"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" assert_eq!(12 + 1, 13);"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":