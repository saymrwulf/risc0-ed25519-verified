end":{"line":213,"col":5}},"generated_from_span":null},"id":2181,"kind":{"StorageDead":113},"comments_before":[]},{"span":{"data":{"file_id":5,"beg":{"line":213,"col":4},"end":{"line":213,"col":5}},"generated_from_span":null},"id":2182,"kind":{"StorageDead":82},"comments_before":[]},{"span":{"data":{"file_id":5,"beg":{"line":213,"col":4},"end":{"line":213,"col":5}},"generated_from_span":null},"id":2183,"kind":{"StorageDead":52},"comments_before":[]},{"span":{"data":{"file_id":5,"beg":{"line":213,"col":4},"end":{"line":213,"col":5}},"generated_from_span":null},"id":2184,"kind":{"StorageDead":23},"comments_before":[]},{"span":{"data":{"file_id":5,"beg":{"line":213,"col":4},"end":{"line":213,"col":5}},"generated_from_span":null},"id":2185,"kind":{"StorageDead":19},"comments_before":[]},{"span":{"data":{"file_id":5,"beg":{"line":213,"col":4},"end":{"line":213,"col":5}},"generated_from_span":null},"id":2186,"kind":{"StorageDead":15},"comments_before":[]},{"span":{"data":{"file_id":5,"beg":{"line":213,"col":4},"end":{"line":213,"col":5}},"generated_from_span":null},"id":2187,"kind":{"StorageDead":11},"comments_before":[]},{"span":{"data":{"file_id":5,"beg":{"line":213,"col":4},"end":{"line":213,"col":5}},"generated_from_span":null},"id":2188,"kind":{"StorageDead":7},"comments_before":[]},{"span":{"data":{"file_id":5,"beg":{"line":213,"col":4},"end":{"line":213,"col":5}},"generated_from_span":null},"id":2189,"kind":{"StorageDead":5},"comments_before":[]},{"span":{"data":{"file_id":5,"beg":{"line":213,"col":4},"end":{"line":213,"col":5}},"generated_from_span":null},"id":2190,"kind":{"StorageDead":3},"comments_before":[]},{"span":{"data":{"file_id":5,"beg":{"line":213,"col":5},"end":{"line":213,"col":5}},"generated_from_span":null},"id":2191,"kind":"Return","comments_before":[]}]},"comments":[[118,["/ Helper function to multiply two 64-bit integers with 128","/ bits of output."]],[122,["Alias self, _rhs for more readable formulas"]],[130,["Precondition: assume input limbs a[i], b[i] are bounded as","","a[i], b[i] < 2^(51 + b)","","where b is a real parameter measuring the \"bit excess\" of the limbs."]],[138,["64-bit precomputations to avoid 128-bit multiplications.","","This fits into a u64 whenever 51 + b + lg(19) < 64.","","Since 51 + b + lg(19) < 51 + 4.25 + b","                      = 55.25 + b,","this fits if b < 8.75."]],[144,["Multiply to get 128-bit coefficients of output"]],[162,["How big are the c[i]? We have","","   c[i] < 2^(102 + 2*b) * (1+i + (4-i)*19)","        < 2^(102 + lg(1 + 4*19) + 2*b)","        < 2^(108.27 + 2*b)","","The carry (c[i] >> 51) fits into a u64 when","   108.27 + 2*b - 51 < 64","   2*b < 6.73","   b < 3.365.","","So we require b < 3 to ensure this fits."]],[171,["Casting to u64 and back tells the compiler that the carry is","bounded by 2^64, so that the addition is a u128 + u64 rather","than u128 + u128."]],[205,["To see that this does not overflow, we need out[0] + carry * 19 < 2^64.","","c4 < a0*b4 + a1*b3 + a2*b2 + a3*b1 + a4*b0 + (carry from c3)","   < 5*(2^(51 + b) * 2^(51 + b)) + (carry from c3)","   < 2^(102 + 2*b + lg(5)) + 2^64.","","When b < 3 we get","","c4 < 2^110.33  so that carry < 2^59.33","","so that","","out[0] + carry * 19 < 2^51 + 19 * 2^59.33 < 2^63.58","","and there is no overflow."]],[208,["Now out[1] < 2^51 + 2^(64 -51) = 2^51 + 2^13 < 2^(51 + epsilon)."]],[212,["Now out[i] < 2^(51 + epsilon) for all i."]]]}}},{"def_id":25,"item_meta":{"name":[{"Ident":["curve25519_dalek",0]},{"Ident":["backend",0]},{"Ident":["serial",0]},{"Ident":["u64",0]},{"Ident":["field",0]},{"Impl":{"Trait":13}},{"Ident":["neg",0]}],"span":{"data":{"file_id":5,"beg":{"line":218,"col":4},"end":{"line":222,"col":5}},"generated_from_span":null},"source_text":"fn neg(self) -> FieldElement51 {\n        let mut output = *self;\n        output.negate();\n        output\n    }","attr_info":{"attributes":[],"inline":null,"rename":null,"public":true},"is_local":true,"opacity":"Transparent","lang_item":null},"generic